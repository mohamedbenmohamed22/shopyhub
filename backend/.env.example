# PostgreSQL connection
# DB_PORT is the host-published port (docker compose maps it to container 5432).
DB_PORT=5430
DATABASE_URL="postgresql://pow:pow@localhost:5430/product_of_the_week?schema=public"

# API
PORT=3000
API_PREFIX=api/v1
CORS_ORIGIN=http://localhost:8080

# Auth
JWT_SECRET="change-me-in-production-use-a-long-random-string"
JWT_EXPIRES_IN=1d

# Seed admin (used by prisma/seed.ts)
ADMIN_EMAIL=admin@potw.tn
ADMIN_PASSWORD=admin1234

# Delivery
DEFAULT_DELIVERY_FEE=7

# MinIO / S3 — product image storage.
# Host-published ports (defaults 9000/9001 are often taken — pick free ones).
MINIO_API_PORT=9090
MINIO_CONSOLE_PORT=9091
S3_ACCESS_KEY=pow-minio
S3_SECRET_KEY=pow-minio-secret
S3_BUCKET=product-images
S3_REGION=us-east-1
# Endpoint the API uses to reach MinIO: "minio:9000" in compose, "localhost:9090" on host.
S3_ENDPOINT=minio
S3_PORT=9000
S3_USE_SSL=false
# Public, browser-reachable base URL stored in product image links.
S3_PUBLIC_URL=http://localhost:9090/product-images
